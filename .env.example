# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=YOUR_APP_KEY_HERE
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# MySQL
DB_ROOT_PASSWORD=YOUR_DB_ROOT_PASSWORD
DB_DATABASE==YOU_DATABASE
DB_USER==YOU_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_HOST=localhost

# Gateways mock
GATEWAY_REMOVE_AUTH=false

GATEWAY1_URL=http://gateways
GATEWAY1_EMAIL==YOU_EMAIL
GATEWAY1_TOKEN=YOU_TOKEN

GATEWAY2_URL=http://gateways
GATEWAY2_AUTH_TOKEN==YOU_TOKEN
GATEWAY2_AUTH_SECRET==YOU_TOKEN_SECRET


# CORS (configure allowed origins for API access)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
